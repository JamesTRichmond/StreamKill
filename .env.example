# StreamKill demo environment variables
# Copy this file to .env locally if needed.
# Never commit .env.

STREAMKILL_ENV=demo
STREAMKILL_DEMO_MODE=true

# Local demo paths
STREAMKILL_LEDGER_PATH=data/demo/demo_ledger.json
STREAMKILL_RECEIPTS_PATH=data/demo/sample_receipts.redacted.json
STREAMKILL_SUBSCRIPTION_CATALOG_PATH=data/catalog/subscriptions.seed.json
STREAMKILL_CANCEL_ROUTES_PATH=data/catalog/cancel_routes.seed.json

# Optional local engine settings
STREAMKILL_LOCAL_ENGINE_URL=http://localhost:8000
STREAMKILL_BROWSER_HEADLESS=false

# Placeholder only. Do not put real secrets in this file.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
OPENAI_API_KEY=
